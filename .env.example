# ============================================
# Backend environment variables (.env.local at project root)
# Used by: backend/app/core/config.py
# ============================================

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/cliniqai

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=
JWT_REFRESH_SECRET=

# Sarvam AI (Voice AI — STT, TTS, Samvaad Agent)
SARVAM_API_KEY=
SARVAM_WEBHOOK_SECRET=
SARVAM_AGENT_ID=

# Exotel (Indian Telephony)
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_SID=
EXOTEL_SUBDOMAIN=

# OpenAI (Embeddings)
OPENAI_API_KEY=

# Anthropic (LLM)
ANTHROPIC_API_KEY=

# Razorpay (Payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Gupshup (WhatsApp)
GUPSHUP_API_KEY=
GUPSHUP_APP_NAME=

# SMS
SMS_API_KEY=

# ============================================
# Frontend environment variables (frontend/.env.local)
# Used by: Next.js (NEXT_PUBLIC_* exposed to browser)
# ============================================

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NODE_ENV=development
